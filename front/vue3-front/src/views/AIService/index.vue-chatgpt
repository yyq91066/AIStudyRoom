  border-top-left-radius: 4px;
  box-shadow: 0 10px 22px rgba(28, 40, 74, 0.08);
}

.msg-content {
  white-space: pre-wrap;
}

.bot-bubble :deep(.markdown-body) {
  background: transparent;
  font-size: 14px;
  line-height: 1.65;
}

.bot-bubble :deep(.markdown-body p) {
  margin: 0.4em 0;
}

.bot-bubble :deep(.markdown-body pre) {
  margin: 0.6em 0;
  padding: 12px;
  border-radius: 12px;
  overflow-x: auto;
}

.bot-bubble :deep(.markdown-body code) {
  border-radius: 6px;
}

.loading-dots {
  display: inline-flex;
  gap: 4px;
  margin-left: 6px;
}

.loading-dots span {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background-color: #6b7280;
  animation: pulse 1.2s infinite ease-in-out;
}

.loading-dots span:nth-child(2) {
  animation-delay: 0.15s;
}

.loading-dots span:nth-child(3) {
  animation-delay: 0.3s;
}

.input-container {
  margin-top: 14px;
  display: flex;
  gap: 12px;
  align-items: flex-end;
  padding: 12px;
  border-radius: 18px;
  background: rgba(255, 255, 255, 0.92);
  border: 1px solid rgba(148, 169, 207, 0.25);
  box-shadow: 0 12px 24px rgba(28, 40, 74, 0.08);
}

.input-container :deep(.el-textarea__inner) {
  border-radius: 14px;
  resize: none;
  padding: 12px;
  line-height: 1.6;
  box-shadow: none;
  background: #f7f9fd;
}

.send-button {
  height: 42px;
  min-width: 82px;
  border-radius: 12px;
  font-weight: 600;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(0.65);
    opacity: 0.45;
  }
  50% {
    transform: scale(1);
    opacity: 1;
  }
}

@keyframes rise {
  from {
    transform: translateY(6px);
    opacity: 0.5;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

@media (max-width: 768px) {
  .app-layout {
    flex-direction: column;
    padding: 12px;
  }

  .sidebar {
    width: 100%;
    box-sizing: border-box;
    flex-direction: row;
    justify-content: space-between;
  }

  .logo-section {
    flex-direction: row;
  }

  .logo-img {
    width: 42px;
    height: 42px;
  }

  .new-chat-button {
    width: auto;
    margin-top: 0;
  }

  .message-bubble {
    max-width: 86%;
  }
}
</style>