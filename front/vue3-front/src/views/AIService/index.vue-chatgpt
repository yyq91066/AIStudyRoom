<template>
  <div class="app-layout">
    <aside class="sidebar">
      <div class="logo-section">
        <img src="@/assets/logo.png" alt="智学空间" class="logo-img" />
        <div class="logo-text">智学空间</div>
      </div>

      <el-button class="new-chat-button" @click="newChat">
        + 新会话
      </el-button>
    </aside>

    <main class="main-content">
      <div class="chat-container">
        <div class="message-list" ref="messageListRef">
          <div
              v-for="(message, index) in messages"
              :key="index"
              :class="['message-row', message.isUser ? 'user-row' : 'bot-row']"
          >
            <div class="avatar">
              {{ message.isUser ? '我' : 'AI' }}
            </div>

            <div :class="['message-bubble', message.isUser ? 'user-bubble' : 'bot-bubble']">
              <div
                  v-if="message.isUser"
                  class="msg-content"
                  v-text="message.content"
              ></div>

              <div
                  v-else
                  class="msg-content markdown-body"
                  v-html="message.contentHtml"
              ></div>

              <span v-if="message.isTyping" class="loading-dots">
                <span></span>
                <span></span>
                <span></span>
              </span>
            </div>
          </div>
        </div>

        <div class="input-container">
          <el-input
              v-model="inputMessage"
              type="textarea"
              :autosize="{ minRows: 1, maxRows: 5 }"
              placeholder="请输入消息，按 Enter 发送，Shift + Enter 换行"
              @keydown.enter.prevent="handleEnter"
          />

          <el-button
              type="primary"
              class="send-button"
              :disabled="isSending || !inputMessage.trim()"
              @click="sendMessage"
          >
            {{ isSending ? '发送中' : '发送' }}
          </el-button>
        </div>
      </div>
    </main>
  </div>
</template>

<script setup>
import { nextTick, onMounted, ref } from 'vue'
import { v4 as uuidv4 } from 'uuid'
import 'github-markdown-css/github-markdown.css'
import { renderMd } from '@/utils/md'

const API_URL = 'http://localhost:8080/aiservice/chat'

const messageListRef = ref(null)
const inputMessage = ref('')
const messages = ref([])
const isSending = ref(false)
const memoryId = ref(null)

onMounted(() => {
  initMemoryId()
  sendRequest('你好', false)
})

const initMemoryId = () => {
  let stored = localStorage.getItem('user_uuid')

  if (!stored) {
    stored = String(uuidToNumber(uuidv4()))
    localStorage.setItem('user_uuid', stored)
  }

  memoryId.value = Number(stored)
}

const uuidToNumber = (uuid) => {
  let number = 0
  for (let i = 0; i < uuid.length && i < 8; i++) {
    const value = parseInt(uuid[i], 16)
    if (!Number.isNaN(value)) {
      number = number * 16 + value
    }
  }
  return number % 1000000
}

const handleEnter = (e) => {
  if (e.shiftKey) {
    inputMessage.value += '\n'
    return
  }

  sendMessage()
}

const sendMessage = () => {
  const text = inputMessage.value.trim()
  if (!text || isSending.value) return

  inputMessage.value = ''
  sendRequest(text, true)
}

const sendRequest = async (text, showUserMessage = true) => {
  if (!text.trim()) return

  isSending.value = true

  if (showUserMessage) {
    messages.value.push({
      isUser: true,
      content: text,
    })
  }

  const botMsg = {
    isUser: false,
    content: '',
    contentHtml: '',
    isTyping: true,
  }

  messages.value.push(botMsg)
  await scrollToBottom()

  try {
    const response = await fetch(API_URL, {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
      },
      body: JSON.stringify({
        memoryId: memoryId.value,
        message: text,
      }),
    })

    if (!response.ok) {
      throw new Error(`HTTP ${response.status}`)
    }

    const reader = response.body.getReader()
    const decoder = new TextDecoder('utf-8')

    while (true) {
      const { done, value } = await reader.read()
      if (done) break

      const chunk = decoder.decode(value, { stream: true })
      botMsg.content += chunk
      botMsg.contentHtml = renderMd(botMsg.content)

      await scrollToBottom()
    }
  } catch (err) {
    console.error(err)
    botMsg.content = '请求失败，请检查后端服务或网络连接。'
    botMsg.contentHtml = renderMd(botMsg.content)
  } finally {
    botMsg.isTyping = false
    isSending.value = false
    await scrollToBottom()
  }
}

const scrollToBottom = async () => {
  await nextTick()
  if (messageListRef.value) {
    messageListRef.value.scrollTop = messageListRef.value.scrollHeight
  }
}

const newChat = () => {
  localStorage.removeItem('user_uuid')
  messages.value = []
  initMemoryId()
  sendRequest('你好', false)
}
</script>

<style scoped>
