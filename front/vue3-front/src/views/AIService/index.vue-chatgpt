  flex: 1;
  overflow-y: auto;
  padding: 18px;
  border-radius: 20px;
  background: linear-gradient(180deg, #ffffff 0%, #f6f8fc 100%);
  border: 1px solid rgba(148, 169, 207, 0.25);
}

