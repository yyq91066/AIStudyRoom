.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f7fb;
}

.message-list {
  flex: 1;
  padding: 20rpx;
  overflow-y: auto;
}

.message {
  display: flex;
  align-items: flex-start;
  margin-bottom: 24rpx;
  animation: message-rise 0.25s ease;
}

.user-message {
  flex-direction: row-reverse;
}

.message-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4b7bff 0%, #3ad0c4 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 16rpx;
}

.avatar-icon {
  font-size: 36rpx;
  color: #ffffff;
}

.message-content {
  max-width: 70%;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
}

.user-message .message-content {
  background: linear-gradient(135deg, #d7e7ff 0%, #bfe4f4 100%);
  color: #1b1f2b;
}

.bot-message .message-content {
  background: #ffffff;
  color: #1b1f2b;
  border: 1rpx solid rgba(148, 169, 207, 0.25);
}

.loading-dots {
  display: inline-flex;
  margin-left: 10rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  background-color: #000000;
  border-radius: 50%;
  margin-left: 10rpx;
  animation: pulse 1.2s infinite ease-in-out both;
}

.dot:nth-child(2) {
  animation-delay: -0.6s;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(0.6);
    opacity: 0.4;
  }
  50% {
    transform: scale(1);
    opacity: 1;
  }
}

@keyframes message-rise {
  from {
    transform: translateY(12rpx);
    opacity: 0.6;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.input-container {
  display: flex;
  gap: 20rpx;
  padding: 24rpx;
  background: rgba(255, 255, 255, 0.85);
  border-top: 1rpx solid rgba(148, 169, 207, 0.25);
}

.input-container .input-field {
  flex: 1;
  background: #f7f9fd;
  border: 1rpx solid rgba(148, 169, 207, 0.45);
  border-radius: 14rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.send-button {
  width: 140rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: linear-gradient(135deg, #4b7bff 0%, #6a5dff 100%);
  color: #ffffff;
  border-radius: 12rpx;
  font-size: 28rpx;
  padding: 0;
}

.send-button[disabled] {
  background: #cccccc;
  color: #999999;
}
