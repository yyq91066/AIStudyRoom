.register-container {
  display: flex;
  flex-direction: column;
  padding: 60rpx 40rpx;
  min-height: 100vh;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.9) 0%, #f5f7fb 100%);
}

.header {
  margin-bottom: 60rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #1b1f2b;
}

.form-section {
  width: 100%;
}

.input-item {
  margin-bottom: 30rpx;
}

.code-input {
  display: flex;
  gap: 20rpx;
}

.code-input .input-field {
  flex: 1;
}

.code-button {
  width: 200rpx;
  height: 88rpx;
  line-height: 88rpx;
  background: #4b7bff;
  color: #ffffff;
  border-radius: 14rpx;
  font-size: 26rpx;
  padding: 0;
}

.code-button[disabled] {
  background: #cccccc;
  color: #999999;
}

.button-primary {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  margin-top: 40rpx;
  font-size: 32rpx;
}
