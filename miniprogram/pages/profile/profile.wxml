<view class="profile-container">
  <view class="user-header">
    <view class="avatar">
      <text class="avatar-icon fa-user"></text>
    </view>
    <view class="user-info">
      <text class="username">{{userInfo.username || '未登录'}}</text>
      <text class="email">{{userInfo.email || '点击登录完善信息'}}</text>
    </view>
  </view>
  
  <view class="menu-section">
    <view class="menu-item" bindtap="goToUpdateProfile">
      <text class="menu-label">个人信息</text>
      <text class="menu-arrow">></text>
    </view>
    
    <view class="menu-item" bindtap="goToUpdatePassword">
      <text class="menu-label">修改密码</text>
      <text class="menu-arrow">></text>
    </view>
    
    <view class="menu-item" bindtap="clearCache">
      <text class="menu-label">清除缓存</text>
      <text class="menu-value">{{cacheSize}}MB</text>
    </view>
  </view>
  
  <button class="logout-button" bindtap="onLogout">退出登录</button>
</view>
