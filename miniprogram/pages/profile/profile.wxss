.profile-container {
  padding: 40rpx;
  min-height: 100vh;
  background: #f5f7fb;
}

.user-header {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #4b7bff 0%, #3ad0c4 100%);
  padding: 60rpx 40rpx;
  border-radius: 24rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 18rpx 40rpx rgba(30, 45, 90, 0.1);
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 32rpx;
}

.avatar-icon {
  font-size: 60rpx;
  color: #ffffff;
}

.user-info {
  flex: 1;
}

.username {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 12rpx;
}

.email {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.menu-section {
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 40rpx;
}

.menu-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx 40rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-label {
  font-size: 30rpx;
  color: #1b1f2b;
}

.menu-arrow {
  color: #999;
  font-size: 28rpx;
}

.menu-value {
  color: #999;
  font-size: 28rpx;
}

.logout-button {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #ff4d4f;
  color: #ffffff;
  border-radius: 14rpx;
  font-size: 32rpx;
  font-weight: 600;
}
