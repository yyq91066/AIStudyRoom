<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="org.example.aidemo.wechat.mapper.WxUserMapper">
    <insert id="insertWxUser" parameterType="org.example.aidemo.wechat.model.WxUser" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO wx_user (
            id,
            openid,
            username,
            password,
            balance,
            nickname,
            email,
            user_pic,
            create_time,
            update_time
        ) VALUES (
                     #{id},
                     #{openid},
                     #{username},
                     #{password},
                     #{balance},
                     #{nickname},
                     #{email},
                     #{userPic},
                     #{createTime},
                     #{updateTime}
                 )
    </insert>
</mapper>
